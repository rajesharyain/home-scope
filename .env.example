# HomeScope Environment Configuration
# Copy this to .env and fill in your values

# Optional: AI Summary (leave blank to use built-in fallback summary)
OPENAI_API_KEY=sk-...

# Optional: Better walking/driving distances (leave blank to use estimates)
OPENROUTE_API_KEY=...

# Database (only needed if running locally without Docker)
DATABASE_URL=postgresql://homescope:homescope@localhost:5432/homescope

# Redis (only needed if running locally without Docker)
REDIS_URL=redis://localhost:6379/0

# Debug mode
DEBUG=false
