{
  "manifest_version": 3,
  "name": "HomeScope",
  "version": "1.2.0",
  "description": "AI-powered neighbourhood analysis. Opens as Chrome Side Panel.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "HomeScope – Open Side Panel",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "tabs", "alarms", "sidePanel"],
  "host_permissions": ["http://localhost:8000/*", "http://localhost:8001/*"]
}
